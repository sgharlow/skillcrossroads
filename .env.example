# Skill Crossroads — environment reference (all optional; every feature is env-gated).
# Copy to apps/web/.env.local for local dev. Use TEST keys locally — live keys belong
# only in the hosting provider's env config. See SETUP.md for the full reference.

# Postgres backing for entitlements / gallery / scan history (in-memory fallback when unset)
DATABASE_URL=

# Higher GitHub rate limits for repo scans (fine-grained PAT, public-repo read)
GITHUB_TOKEN=

# Canonical site URL for sitemap/robots/badge embeds (defaults to https://skillcrossroads.com)
NEXT_PUBLIC_SITE_URL=

# Sign in with GitHub (OAuth app credentials)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Pro tier — Stripe (use sk_test_/test price locally)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Required before enabling Pro: HMAC-signs the identity cookie (any long random string)
BEACON_SESSION_SECRET=

# Managed LLM checks for Pro users (server-side Anthropic key)
BEACON_MANAGED_ANTHROPIC_KEY=

# CLI / local scans: enables the LLM-assisted checks (BYOK)
ANTHROPIC_API_KEY=

# Optional overrides
BEACON_MODEL=
BEACON_SITE_URL=
