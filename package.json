{
  "name": "beacon-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Lighthouse for Claude Code artifacts — an evidence-cited quality scorecard, letter grade, and embeddable badge for Skills, subagents, MCP servers, and plugins.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --build packages/cli/tsconfig.json",
    "eval:triggering": "node scripts/eval-triggering.mjs",
    "report:skills": "node scripts/state-of-skills.mjs",
    "beacon": "node packages/cli/dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
